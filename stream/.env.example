# Supabase credentials (use the service role key, NOT the anon key)
# Required for now_playing sync and playlist building
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here

# YouTube Live Stream
YOUTUBE_STREAM_KEY=your-youtube-stream-key
YOUTUBE_RTMP_URL=rtmp://a.rtmp.youtube.com/live2

# Auto-refresh polling interval (ms) — default 30000 (30 seconds)
POLL_INTERVAL_MS=30000
